@page "/reportes"
@using HsqvLogistica.Models.DTOs.Almacen
@using HsqvLogistica.Models.DTOs.Lineas
@using HsqvLogistica.Models.DTOs.Reportes
@using HsqvLogistica.Services.Interfaces
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.False" Class="mt-6 px-6">

    <!-- HEADER -->
    <MudText Typo="Typo.h5" Class="fw-bold mb-1">
        Reportes del Sistema
    </MudText>
    <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-5">
        Generación de reportes y análisis
    </MudText>

    <MudGrid Spacing="4">

        <!-- =========================
             Movimientos (Kardex)
             ========================= -->
        <MudItem xs="12" md="4">
            <MudCard Class="report-card">

                <MudCardHeader Style="background-color:#f3f6fd;">


                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Info" Size="Size.Small">
                            <MudIcon Icon="@Icons.Material.Filled.SyncAlt" />
                        </MudAvatar>
                    </CardHeaderAvatar>

                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                            Movimientos (Kardex)
                        </MudText>
                    </CardHeaderContent>

                </MudCardHeader>

                <MudCardContent>
                    <MudStack Spacing="1">

                        <MudDatePicker Label="Fecha Desde"
                                       @bind-Date="_fechaDesdeKardex"
                                       Margin="Margin.Dense"
                                       Dense="true" />

                        <MudDatePicker Label="Fecha Desde"
                                       @bind-Date="_fechaHastaKardex"
                                       Margin="Margin.Dense"
                                       Dense="true" />

                        <MudSelect T="TipoMovimiento"
                                   Label="Tipo"
                                   Dense
                                   Margin="Margin.Dense"
                                   @bind-Value="_tipo">

                            <MudSelectItem Value="TipoMovimiento.Todos">Todos</MudSelectItem>
                            <MudSelectItem Value="TipoMovimiento.Ingreso">Ingreso</MudSelectItem>
                            <MudSelectItem Value="TipoMovimiento.Salida">Salida</MudSelectItem>

                        </MudSelect>

                    </MudStack>
                </MudCardContent>

                <MudCardActions>
                    <MudButton Color="Color.Success"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               OnClick="ExportarKardexExcel"
                               FullWidth>
                        Exportar Excel
                    </MudButton>
                </MudCardActions>

            </MudCard>
        </MudItem>

        <!-- =========================
             Reporte de Stock
             ========================= -->
        <MudItem xs="12" md="4">
            <MudCard Class="report-card">

                <MudCardHeader Style="background-color:#f3f6fd;">
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Success" Size="Size.Small">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                            Reporte de Stock
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudStack Spacing="1">

                        <MudSelect T="int?"
                                   Label="Almacén"
                                   Dense
                                   Margin="Margin.Dense"
                                   @bind-Value="_idAlmacen">

                            <MudSelectItem Value="@((int?)null)">
                                Todos los almacenes
                            </MudSelectItem>

                            @foreach (var almacen in _almacenes)
                            {
                                <MudSelectItem Value="@((int?)almacen.Id)">
                                    @almacen.Nombre
                                </MudSelectItem>
                            }

                        </MudSelect>

                        <MudSelect T="int?"
                                   Label="Línea"
                                   Dense
                                   Margin="Margin.Dense"
                                   @bind-Value="_idLinea">

                            <MudSelectItem Value="@((int?)null)">
                                Todas las líneas
                            </MudSelectItem>

                            @foreach (var linea in _lineas)
                            {
                                <MudSelectItem Value="@((int?)linea.Id)">
                                    @linea.Descripcion
                                </MudSelectItem>
                            }

                        </MudSelect>

                    </MudStack>
                </MudCardContent>

                <MudCardActions>
                    <MudButton Color="Color.Success"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               OnClick="ExportarStockExcel"
                               FullWidth>

                        Exportar Excel

                    </MudButton>
                </MudCardActions>

            </MudCard>
        </MudItem>

        <!-- =========================
             Reporte Garantías
             ========================= -->
        <MudItem xs="12" md="4">
            <MudCard Class="report-card">

                <MudCardHeader Style="background-color:#f3f6fd;">
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Secondary" Size="Size.Small">
                            <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Class="fw-bold">
                            Reporte Garantías
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudStack Spacing="1">

                        <MudDatePicker Label="Fecha Desde"
                                       @bind-Date="_fechaDesdeGarantia"
                                       Margin="Margin.Dense"
                                       Dense="true" />
                        <MudDatePicker Label="Fecha Desde"
                                       @bind-Date="_fechaHastaGarantia"
                                       Margin="Margin.Dense"
                                       Dense="true" />

                        <MudSelect T="TipoEstadoGarantia"
                                   Label="Estado"
                                   Dense
                                   Margin="Margin.Dense"
                                   @bind-Value="_tipoEstado">

                            <MudSelectItem Value="TipoEstadoGarantia.Todos">Todos</MudSelectItem>
                            <MudSelectItem Value="TipoEstadoGarantia.Pendientes">Pendientes</MudSelectItem>
                            <MudSelectItem Value="TipoEstadoGarantia.Cerrados">Cerrados</MudSelectItem>

                        </MudSelect>

                    </MudStack>
                </MudCardContent>

                <MudCardActions>
                    <MudButton Color="Color.Success"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.FileDownload"
                               OnClick="ExportarGarantiaExcel"
                               FullWidth>
                        Exportar Excel
                    </MudButton>
                </MudCardActions>

            </MudCard>
        </MudItem>

    </MudGrid>

</MudContainer>

@code {

    [Inject] private IAlmacenService AlmacenService { get; set; } = default!;
    [Inject] private ILineaService LineaService { get; set; } = default!;
    [Inject] private IReporteService ReporteService { get; set; } = default!;
    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;

    private TipoMovimiento _tipo = TipoMovimiento.Todos;
    private TipoEstadoGarantia _tipoEstado = TipoEstadoGarantia.Todos;

    private int? _idAlmacen;
    private int? _idLinea;

    private List<AlmacenDto> _almacenes = new();
    private List<LineaDto> _lineas = new();

    private DateTime? _fechaDesdeKardex =
        new(DateTime.Today.Year, DateTime.Today.Month, 1);

    private DateTime? _fechaHastaKardex =
        DateTime.Today;

    private DateTime? _fechaDesdeGarantia =
        new(DateTime.Today.Year, DateTime.Today.Month, 1);

    private DateTime? _fechaHastaGarantia =
        DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await CargarCombosAsync();
    }

    private async Task CargarCombosAsync()
    {
        _almacenes = (await AlmacenService.GetAllAsync())
            .OrderBy(x => x.Nombre)
            .ToList();

        _lineas = (await LineaService.GetAllAsync())
            .OrderBy(x => x.Descripcion)
            .ToList();
    }

    private async Task ExportarStockExcel()
    {
        var filtro = new ReporteStockFilterDto
        {
            IdAlmacen = _idAlmacen,
            IdLinea = _idLinea
        };

        var archivo = await ReporteService.ExportarStockExcelAsync(filtro);

        await JSRuntime.InvokeVoidAsync(
            "downloadFile",
            "ReporteStock.xlsx",
            Convert.ToBase64String(archivo));
    }

    private bool? ObtenerEstadoGarantia()
    {
        return _tipoEstado switch
        {
            TipoEstadoGarantia.Todos => null,
            TipoEstadoGarantia.Pendientes => false,
            TipoEstadoGarantia.Cerrados => true,
            _ => null
        };
    }

    private async Task ExportarGarantiaExcel()
    {
        var filtro = new ReporteGarantiaFilterDto
        {
            FechaDesde = _fechaDesdeGarantia!.Value,
            FechaHasta = _fechaHastaGarantia!.Value,
            Estado = ObtenerEstadoGarantia()
        };

        var archivo = await ReporteService.ExportarGarantiasExcelAsync(filtro);

        await JSRuntime.InvokeVoidAsync(
            "downloadFile",
            "ReporteGarantia.xlsx",
            Convert.ToBase64String(archivo));
    }

    public enum TipoMovimiento
    {
        Todos,
        Ingreso,
        Salida
    }

    public enum TipoEstadoGarantia
    {
        Todos,
        Pendientes,
        Cerrados
    }
    
    private async Task ExportarKardexExcel()
    {
        var filtro = new ReporteKardexFilterDto
        {
            FechaDesde = _fechaDesdeKardex!.Value,
            FechaHasta = _fechaHastaKardex!.Value,

            //Si tu Kardex trabaja por almacén
            IdAlmacen = _idAlmacen ?? 1,
            IdLinea = null,
            IdArticulo = null
        };

        byte[] archivo;

        switch (_tipo)
        {
            case TipoMovimiento.Todos:

                archivo = await ReporteService.ExportarKardexExcelAsync(filtro);
                break;

            case TipoMovimiento.Ingreso:

                archivo = await ReporteService.ExportarIngresosExcelAsync(filtro);
                break;

            case TipoMovimiento.Salida:

                archivo = await ReporteService.ExportarSalidasExcelAsync(filtro);
                break;

            default:

                archivo = await ReporteService.ExportarKardexExcelAsync(filtro);
                break;
        }

        await JSRuntime.InvokeVoidAsync(
            "downloadFile",
            "ReporteKardex.xlsx",
            Convert.ToBase64String(archivo));
    }
}
