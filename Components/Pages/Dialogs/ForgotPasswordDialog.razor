@using HsqvLogistica.Services.Interfaces
@using MudBlazor

@inject IUsuarioService UsuarioService
@inject INotificationService NotificationService

<MudDialog>

    <TitleContent>
        <MudText Typo="Typo.h6">
            Recuperar contraseña
        </MudText>
    </TitleContent>

    <DialogContent>

        <MudText Class="mb-4">
            Ingrese su nombre de usuario. Si existe una cuenta activa asociada,
            se enviarán las credenciales al correo registrado.
        </MudText>

        <MudTextField T="string"
                      Label="Usuario"
                      @bind-Value="_usuario"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      FullWidth="true"
                      Immediate="true"
                      Disabled="_loading"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Person" />

        @if (!string.IsNullOrWhiteSpace(_mensaje))
        {
            <MudAlert Severity="@_severity"
                      Dense="true"
                      Class="mt-4">

                @_mensaje

            </MudAlert>
        }

    </DialogContent>

    <DialogActions>

        <MudButton Color="Color.Default"
                   Disabled="_loading"
                   OnClick="Cancelar">

            Cancelar

        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_loading"
                   OnClick="Enviar">

            @(_loading ? "Enviando..." : "Enviar correo")

        </MudButton>

    </DialogActions>

</MudDialog>

@code
{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private string _usuario = string.Empty;

    private bool _loading;

    private string? _mensaje;

    private Severity _severity;

    private void Cancelar()
    {
        MudDialog.Cancel();
    }

    private async Task Enviar()
    {
        if (string.IsNullOrWhiteSpace(_usuario))
        {
            _severity = Severity.Warning;
            _mensaje = "Ingrese su nombre de usuario.";
            return;
        }

        _loading = true;
        _mensaje = null;

        try
        {
            var usuario = await UsuarioService.GetByUsuarioAsync(_usuario);

            if (usuario is null)
            {
                _severity = Severity.Warning;
                _mensaje = "No existe un usuario registrado con ese nombre.";
                return;
            }

            await NotificationService.NotificarRecuperacionPasswordAsync(usuario.Id);

            _severity = Severity.Success;
            _mensaje = "Las credenciales fueron enviadas correctamente al correo registrado.";

            await Task.Delay(1800);

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch
        {
            _severity = Severity.Error;
            _mensaje = "Ocurrió un error al enviar el correo.";
        }
        finally
        {
            _loading = false;
        }
    }
}