@using HsqvLogistica.Helpers
@using HsqvLogistica.Models.DTOs.Articulos
@using HsqvLogistica.Models.DTOs.Lineas
@using HsqvLogistica.Services.Interfaces
@using MudBlazor
@inject IUserSessionService UserSession

<MudDialog>

    <DialogContent>

        <MudText Typo="Typo.body2"
                 Color="Color.Secondary"
                 Class="mb-4">
            Complete los datos del artículo
        </MudText>

        <MudForm @ref="_form">

            <!-- Código -->
            <MudTextField Label="Código"
                          @bind-Value="_codigo"
                          Disabled="@_isEditMode"
                          Required
                          Variant="Variant.Outlined"
                          Color="Color.Primary"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.QrCode" />

            <!-- Descripción -->
            <MudTextField Label="Descripción"
                          @bind-Value="_descripcion"
                          Required
                          Variant="Variant.Outlined"
                          Color="Color.Primary"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Description" />

            <!-- Línea -->
            <MudSelect T="int"
                       Label="Línea"
                       @bind-Value="_idLinea"
                       Required
                       Dense
                       Searchable
                       Clearable
                       Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Adornment="Adornment.Start"
                       AdornmentIcon="@Icons.Material.Filled.Category">

                @foreach (var linea in Lineas)
                {
                    <MudSelectItem Value="@linea.Id">
                        @linea.Descripcion
                    </MudSelectItem>
                }
            </MudSelect>

            <!-- Detalles -->
            <MudTextField Label="Detalles"
                          @bind-Value="_detalles"
                          Lines="3"
                          Variant="Variant.Outlined"
                          Color="Color.Primary"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Notes" />

            <!-- Ruta Imagen -->
            <MudTextField Label="Ruta de imagen"
                          @bind-Value="_rutaImagen"
                          Placeholder="/images/productos/ejemplo.png"
                          Variant="Variant.Outlined"
                          Color="Color.Primary"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Image" />

            <MudDivider Class="my-3" />

            <MudDivider Class="my-3" />

            <MudGrid Spacing="2">

                <!-- Stock -->
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Label="Stock"
                                     @bind-Value="_stock"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Inventory"
                                     FullWidth />
                </MudItem>

                <!-- Stock Fijo -->
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Label="Stock Fijo"
                                     @bind-Value="_stockFijo"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.Inventory"
                                     FullWidth />
                </MudItem>

                <!-- Precio MN -->
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Label="Precio MN"
                                     @bind-Value="_precioMn"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.AttachMoney"
                                     FullWidth />
                </MudItem>

                <!-- Precio US -->
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal"
                                     Label="Precio US"
                                     @bind-Value="_precioUs"
                                     Variant="Variant.Outlined"
                                     Color="Color.Primary"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.CurrencyExchange"
                                     FullWidth />
                </MudItem>

            </MudGrid>

        </MudForm>

    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Text"
                   Color="Color.Default"
                   OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Save">
            @(_isEditMode ? "Actualizar" : "Guardar")
        </MudButton>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public ArticuloDto? Articulo { get; set; }
    [Parameter] 
    public List<LineaLookupDto> Lineas { get; set; } = new();

    [Inject]
    public IArticuloService ArticuloService { get; set; } = default!;

    MudForm? _form;
    bool _isEditMode;

    string _codigo = string.Empty;
    string _descripcion = string.Empty;
    decimal _stock;
    decimal _stockFijo;
    decimal _precioMn;
    decimal _precioUs;
    int _idLinea;
    string _rutaImagen = string.Empty;
    string _detalles = string.Empty;

    protected override void OnInitialized()
    {
        if (Articulo != null)
        {
            _isEditMode = true;
            _codigo = Articulo.Codigo ?? "";
            _descripcion = Articulo.Descripcion ?? "";
            _stock = Articulo.Stock.Value;
            _stockFijo = Articulo.StockFijo ?? 0;

            _precioMn = Articulo.PrecioMn ?? 0;
            _precioUs = Articulo.PrecioUs ?? 0;
            _idLinea = Articulo.IdLinea ?? 0; 
            _rutaImagen = Articulo.RutaImagen ?? "";
            _detalles = Articulo.Detalles ?? "";
        }
    }

    async Task Save()
    {
        if (_form is null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        if (_isEditMode && Articulo != null)
        {
            await ArticuloService.UpdateAsync(
                Articulo.Id,
                new ArticuloUpdateDto
                {
                    Descripcion = TextHelper.Upper(_descripcion),
                    Stock = _stock,
                    StockFijo = _stockFijo,
                    PrecioMn = _precioMn,
                    PrecioUs = _precioUs,
                    RutaImagen = _rutaImagen,
                    IdLinea = _idLinea,
                    Detalles = _detalles,
                    UsuaModifica = UserSession.UsuarioActual.Usuario
                });
        }
        else
        {
            await ArticuloService.CreateAsync(
                new ArticuloCreateDto
                {
                    Codigo = _codigo,
                    Descripcion = TextHelper.Upper(_descripcion),
                    Stock = _stock,
                    StockFijo = _stockFijo,
                    PrecioMn = _precioMn,
                    PrecioUs = _precioUs,
                    RutaImagen = _rutaImagen,
                    IdLinea = _idLinea,
                    Detalles = _detalles,
                    UsuaCreacion = UserSession.UsuarioActual.Usuario
                });
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    void Cancel() => MudDialog.Cancel();
}
