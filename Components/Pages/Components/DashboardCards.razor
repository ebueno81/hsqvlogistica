@using HsqvLogistica.Models.DTOs.Dashboard
@using MudBlazor

@inject NavigationManager Navigation

<MudGrid Spacing="3">

    <MudItem xs="12" sm="6" md="3">
        <div style="cursor:pointer"
             @onclick='() => Ir("/articulos")'>

            <DashboardCard Title="Total Artículos"
                           Value="@Resumen?.TotalArticulos"
                           Icon="@Icons.Material.Filled.Inventory"
                           Color="Color.Primary"
                           Delta="+12%" />

        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div style="cursor:pointer"
             @onclick='() => Ir("/kardex")'>

            <DashboardCard Title="Stock Total"
                           Value="@Resumen?.StockTotal"
                           Icon="@Icons.Material.Filled.Warehouse"
                           Color="Color.Success"
                           Delta="-3%" />

        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div style="cursor:pointer"
             @onclick='() => Ir("/pedidos")'>

            <DashboardCard Title="Pedidos Activos"
                           Value="@Resumen?.PedidosActivos"
                           Icon="@Icons.Material.Filled.LocalShipping"
                           Color="Color.Warning"
                           Delta="+8%" />

        </div>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <div style="cursor:pointer"
             @onclick='() => Ir("/garantias")'>

            <DashboardCard Title="Garantías"
                           Value="@Resumen?.Garantias"
                           Icon="@Icons.Material.Filled.Shield"
                           Color="Color.Info"
                           Delta="-15%" />

        </div>
    </MudItem>

</MudGrid>

@code {
    [Parameter]
    public DashboardSummaryDto? Resumen { get; set; }

    private void Ir(string pagina)
    {
        Navigation.NavigateTo(pagina);
    }
}